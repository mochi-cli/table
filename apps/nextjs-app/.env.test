NEXTJS_DIR=../nextjs-app
TEST_LOG_LEVEL=error
PORT=3000
SOCKET_PORT=3001
PUBLIC_ORIGIN=http://127.0.0.1:3000
ASSET_PREFIX=http://127.0.0.1:3000
STORAGE_PREFIX=http://127.0.0.1:3000

ENABLE_GLOBAL_ERROR_LOGGING=true
API_DOC_DISENABLED=false
CALC_CHUNK_SIZE=400
ENABLE_CANARY_FEATURE=true

MOCHI_LOCAL_AUTH_DISABLED=true
NEXT_PUBLIC_MOCHI_LOCAL_AUTH_DISABLED=true
MOCHI_SQLITE_ENABLED=true
MOCHI_SQLITE_DATABASE_PATH=./data/mochi-table-test.sqlite
