NEXT_BUILD_ENV_OUTPUT=classic
NEXT_BUILD_ENV_SOURCEMAPS=false
NEXT_BUILD_ENV_CSP=false
NEXT_BUILD_ENV_SENTRY_ENABLED=false
NEXT_BUILD_ENV_SENTRY_UPLOAD_DRY_RUN=false
NEXT_PUBLIC_BUILD_VERSION=local

NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
APP_CACHE_DSN=

LOG_LEVEL=info
NEXTJS_DIR=../nextjs-app
PORT=3910
SOCKET_PORT=3911
PUBLIC_ORIGIN=http://localhost:3910
API_DOC_ENABLED_SNIPPET=true
I18NEXT_DEFAULT_CONFIG_PATH=${NEXTJS_DIR}/next-i18next.config.js

MOCHI_LOCAL_AUTH_DISABLED=true
NEXT_PUBLIC_MOCHI_LOCAL_AUTH_DISABLED=true
MOCHI_SQLITE_ENABLED=true
MOCHI_SQLITE_DATABASE_PATH=./data/mochi-table.sqlite
BACKEND_CACHE_PROVIDER=redis
BACKEND_CACHE_REDIS_URI=redis://127.0.0.1:6379/0
